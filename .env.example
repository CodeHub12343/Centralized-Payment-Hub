# ================================================
# Centralized Payment Hub - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values
# For local development, create a .env.local file

# ================================================
# APPLICATION ENVIRONMENT
# ================================================
APP_ENV=production
APP_DEBUG=false
APP_DOMAIN=https://pay.pivotpointinv.com

# ================================================
# DATABASE CONFIGURATION
# Option 1: Local Server
# ================================================
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=your_database_password
# DB_NAME=payment_hub

# ================================================
# DATABASE CONFIGURATION
# Option 2: Railway Remote Database (Recommended for Production)
# ================================================
DB_HOST=yamanote.proxy.rlwy.net
DB_PORT=25898
DB_USER=root
DB_PASS=your_railway_password_here
DB_NAME=railway

# ================================================
# PAWAPAY CONFIGURATION
# ================================================
# Get these from your PawaPay Sandbox/Live account
PAWAPAY_API_TOKEN=your_pawapay_api_token_here
PAWAPAY_API_URL=https://sandbox.pawapay.io
PAWAPAY_MERCHANT_ID=303

# ================================================
# SECURITY CONFIGURATION
# ================================================
# Enforce HTTPS connections
FORCE_HTTPS=true

# ================================================
# MAIL CONFIGURATION (Optional)
# ================================================
# For payment notifications
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_FROM_ADDRESS=noreply@pay.yourdomain.com

# ================================================
# LOGGING
# ================================================
# Log all payment and webhook events
LOG_LEVEL=debug
LOG_CHANNEL=stack

# ================================================
# SESSION CONFIGURATION
# ================================================
SESSION_NAME=ph_admin_session
SESSION_TIMEOUT=3600

# ================================================
# RATE LIMITING
# ================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ATTEMPTS=100
RATE_LIMIT_WINDOW=3600
